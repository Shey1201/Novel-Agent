{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "installCommand": "cd frontend && rm -f package-lock.json && npm install --force",
  "buildCommand": "cd frontend && npm run build"
}
